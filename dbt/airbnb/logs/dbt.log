[0m10:01:19.882499 [debug] [Thread-3 (]: On model.tokyo_airbnb.monthly_occupancy: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "tokyo_airbnb", "target_name": "dev", "node_id": "model.tokyo_airbnb.monthly_occupancy"} */

  
    
    

    create  table
      "tokyo_airbnb"."main_marts"."monthly_occupancy__dbt_tmp"
  
    as (
      WITH calendar AS (
    SELECT * FROM "tokyo_airbnb"."main_marts"."fct_calendar"
),

listings AS (
    SELECT listing_id, neighbourhood, room_type
    FROM "tokyo_airbnb"."main_marts"."dim_listing"
),

monthly AS (
    SELECT
        DATE_TRUNC('month', calendar_date)::DATE AS month,
        c.listing_id,
        l.neighbourhood,
        l.room_type,
        COUNT(*) AS days_in_month,
        SUM(CASE WHEN c.is_available THEN 0 ELSE 1 END) AS booked_days,
        ROUND(AVG(c.price), 2) AS avg_price,
        ROUND(SUM(CASE WHEN c.is_available THEN 0 ELSE c.price END), 2) AS estimated_revenue
    FROM calendar c
    JOIN listings l ON c.listing_id = l.listing_id
    GROUP BY month, c.listing_id, l.neighbourhood, l.room_type
)

SELECT
    month,
    listing_id,
    neighbourhood,
    room_type,
    days_in_month,
    booked_days,
    (days_in_month - booked_days) AS available_days,
    ROUND(booked_days * 100.0 / NULLIF(days_in_month, 0), 1) AS occupancy_rate_pct,
    avg_price,
    estimated_revenue,
    ROUND(estimated_revenue / NULLIF(booked_days, 0), 2) AS avg_daily_rate
FROM monthly
    );
  
  
